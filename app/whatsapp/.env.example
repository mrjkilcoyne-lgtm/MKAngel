# MKAngel WhatsApp bridge -- configuration template.
# Copy this file to `.env` in the same directory and fill it in.
# Never commit the real `.env`.

# Anthropic API key used by the Claude Agent SDK.
ANTHROPIC_API_KEY=sk-ant-...

# Comma-separated WhatsApp numbers (digits only, country code included,
# no +, no spaces) that are allowed to trigger the agent.
# Messages from anyone else are silently dropped.
WHATSAPP_ALLOWLIST=447700900123

# Absolute path to the MKAngel checkout the agent should operate on.
# Defaults to the repo containing this file if left blank.
WHATSAPP_REPO_ROOT=

# Optional overrides.
CLAUDE_MODEL=claude-opus-4-6
WHATSAPP_MAX_TURNS=20
WHATSAPP_LOG_FILE=
LOG_LEVEL=INFO
